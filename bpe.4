#include <stdio.h>
#include <stdlib.h>

// function for exersice 6
int isPrime(int x){
    if(x < 2) return 0;

    for(int i = 2; i <= x/2; i++){
        if(x % i == 0){
            return 0;
        }
    }
    return 1;
}

int main()
{
    int choice;

    printf("Choose exercise (1-8): ");
    scanf("%d", &choice);

    switch (choice)
    {
        case 1:
        {

            int n, m, i, j;
            int a[100][100];

            printf("Enter n and m: ");
            scanf("%d %d", &n, &m);

            printf("Enter matrix:\n");
            for(i = 0; i < n; i++) {
                for(j = 0; j < m; j++) {
                    scanf("%d", &a[i][j]);
                }
            }

            int rowsIncreasing = 1;
            int colsDecreasing = 1;

            for(i = 0; i < n; i++) {
                for(j = 0; j < m - 1; j++) {
                    if(a[i][j] > a[i][j + 1]) {
                        rowsIncreasing = 0;
                        break;
                    }
                }
                if(rowsIncreasing == 0) {
                    break;
                }
            }

            for(j = 0; j < m; j++) {
                for(i = 0; i < n - 1; i++) {
                    if(a[i][j] < a[i + 1][j]) {
                        colsDecreasing = 0;
                        break;
                    }
                }
                if(colsDecreasing == 0) {
                    break;
                }
            }

            if(rowsIncreasing && colsDecreasing) {
                printf("Yes\n");
            } else {
                printf("No\n");
            }

            break;
        }
    
        case 2:
        {

            int n, m, i, j, r, c;
            int a[100][100];

            printf("Enter n and m: ");
            scanf("%d %d", &n, &m);

            printf("Enter matrix:\n");
            for(i = 0; i < n; i++) {
                for(j = 0; j < m; j++) {
                    scanf("%d", &a[i][j]);
                }
            }

            int maxSum = -1000000000;
            int bestNumber = a[0][0];
            int bestRow = 0, bestCol = 0;

            for(i = 0; i < n; i++) {
                for(j = 0; j < m; j++) {

                    int sum = 0;

                    for(r = i - 1; r <= i + 1; r++) {
                        for(c = j - 1; c <= j + 1; c++) {

                            if(r >= 0 && r < n && c >= 0 && c < m) {

                                if(!(r == i && c == j)) {
                                    sum += a[r][c];
                                }
                            }
                        }
                    }

                    if(sum > maxSum) {
                        maxSum = sum;
                        bestNumber = a[i][j];
                        bestRow = i;
                        bestCol = j;
                    }
                }
            }

            printf("Number: %d\n", bestNumber);
            printf("Neighbour sum: %d\n", maxSum);
            printf("Position: row %d, col %d\n", bestRow + 1, bestCol + 1);

            break;
        }

        case 3:
        {
            int n, m, i, j;
            int a[100][100];

            scanf("%d %d", &n, &m);

            for(i = 0; i < n; i++) {
                for(j = 0; j < m; j++) {
                    scanf("%d", &a[i][j]);
                }
            }

            int min = a[0][0], max = a[0][0];
            int minRow = 0, maxRow = 0;

            for(i = 0; i < n; i++) {
                for(j = 0; j < m; j++) {
                    if(a[i][j] > max) {
                        max = a[i][j];
                        maxRow = i;
                    }
                    if(a[i][j] < min) {
                        min = a[i][j];
                        minRow = i;
                    }
                }
            }

            for(j = 0; j < m; j++) {
                int temp = a[minRow][j];
                a[minRow][j] = a[maxRow][j];
                a[maxRow][j] = temp;
            }

            for(i = 0; i < n; i++) {
                for(j = 0; j < m; j++) {
                    printf("%d ", a[i][j]);
                }
                printf("\n");
            }

            break;
        }

        case 4:
        {

            int n, m, i;

            printf("Enter number of people (N): ");
            scanf("%d", &n);

            printf("Enter number of friendships (M): ");
            scanf("%d", &m);

            int degree[100001] = {0};

            printf("Enter the friendships as pairs: person1 person2\n");
            printf("Example: 1 3 means 1 is friend with 3 and 3 is friend with 1\n");

            for(i = 0; i < m; i++) {
                int u, v;
                printf("Friendship %d: ", i + 1);
                scanf("%d %d", &u, &v);

                degree[u]++;
                degree[v]++;
            }

            int x;
            printf("Enter a person number to check how many friends they have: ");
            scanf("%d", &x);

            printf("Person %d has %d friends.\n", x, degree[x]);

            break;

        }

        case 5:
        {
            int arr[1000];
            int n = 0;

            printf("Commands:\n");
            printf("1 x  -> add x\n");
            printf("2 x  -> delete all occurrences of x\n");
            printf("3 x  -> print the x-th smallest number\n");
            printf("0    -> stop program\n");

            while(1) {
                int cmd;
                printf("\nEnter command: ");
                scanf("%d", &cmd);

                if(cmd == 0) {
                    break;
                }

                int x;
                printf("Enter x: ");
                scanf("%d", &x);

                if(cmd == 1) {
                    arr[n] = x;
                    n++;

                    int j = n - 1;
                    while(j > 0 && arr[j] < arr[j - 1]) {
                        int temp = arr[j];
                        arr[j] = arr[j - 1];
                        arr[j - 1] = temp;
                        j--;
                    }

                    printf("Added %d\n", x);
                }
                else if(cmd == 2) {
                    int k = 0;
                    for(int j = 0; j < n; j++) {
                        if(arr[j] != x) {
                            arr[k++] = arr[j];
                        }
                    }
                    n = k;

                    printf("Deleted all occurrences of %d\n", x);
                }
                else if(cmd == 3) {
                    if(x >= 1 && x <= n) {
                        printf("The %d-th smallest number is %d\n", x, arr[x - 1]);
                    } else {
                        printf("Invalid position!\n");
                    }
                }
                else {
                    printf("Invalid command!\n");
                }

                printf("Current numbers: ");
                for(int j = 0; j < n; j++) {
                    printf("%d ", arr[j]);
                }
                printf("\n");
                }

            break;
        }

        case 6:
        {
            int n, i;

            printf("Enter n: ");
            scanf("%d", &n);

            int *arr = (int*)malloc(n * sizeof(int));

            printf("Enter numbers:\n");
            for(i = 0; i < n; i++){
                scanf("%d", &arr[i]);
            }

            int *primes = (int*)malloc(n * sizeof(int));

            int countPrimes = 0;
            int countOthers = 0;

            int *others = (int*)malloc(n * sizeof(int));

            for(i = 0; i < n; i++){
                if(isPrime(arr[i])){
                    primes[countPrimes++] = arr[i];
                } else {
                    others[countOthers++] = arr[i];
                }
            }

            printf("Non-prime numbers:\n");
            for(i = 0; i < countOthers; i++){
                printf("%d ", others[i]);
            }

            printf("\nPrime numbers:\n");
            for(i = 0; i < countPrimes; i++){
                printf("%d ", primes[i]);
            }

            free(arr);
            free(primes);
            free(others);

            break;
        }

        case 7:
        {
            int n, m, i, j, r, c;
            int a[100][100];

            printf("Enter n and m: ");
            scanf("%d %d", &n, &m);

            if(n < 3 || m < 3) {
                printf("No 3x3 submatrix can be formed.\n");
                return 0;
            }

            printf("Enter matrix:\n");
            for(i = 0; i < n; i++) {
                for(j = 0; j < m; j++) {
                    scanf("%d", &a[i][j]);
                }
            }

            int maxSum = 0;
            int startRow = 0, startCol = 0;
            int first = 1;

            for(i = 0; i < n - 2; i++) {
                for(j = 0; j < m - 2; j++) {

                    int sum = 0;

                    for(r = i; r < i + 3; r++) {
                        for(c = j; c < j + 3; c++) {
                            sum += a[r][c];
                        }
                    }

                    if(first || sum > maxSum) {
                        maxSum = sum;
                        startRow = i;
                        startCol = j;
                        first = 0;
                    }
                }
            }

            printf("Max sum = %d\n", maxSum);
            printf("Submatrix 3x3:\n");

            for(i = startRow; i < startRow + 3; i++) {
                for(j = startCol; j < startCol + 3; j++) {
                    printf("%d ", a[i][j]);
                }
                printf("\n");
             }

            break;
        }

        case 8:
        {
            int i;
            int size = 10;
            int *arr = (int*)malloc(size * sizeof(int));

            printf("Enter 10 numbers:\n");
            for(i = 0; i < size; i++) {
                scanf("%d", &arr[i]);
            }

            while(1) {
                int x;
                printf("Enter number (0 to stop): ");
                scanf("%d", &x);

                if(x == 0) {
                    break;
                }

                int pos;
                printf("Enter position: ");
                scanf("%d", &pos);

                if(pos < 0 || pos > size) {
                    printf("Invalid position!\n");
                    continue;
                }

                size++;
                arr = (int*)realloc(arr, size * sizeof(int));

                for(i = size - 1; i > pos; i--) {
                    arr[i] = arr[i - 1];
                }

                arr[pos] = x;
            }

            printf("Result:\n");
            for(i = 0; i < size; i++) {
                printf("%d ", arr[i]);
            }
            printf("\n");

            free(arr);

            break;
        }

        default:
        {
            printf("Invalid choice.\n");
            break;
        }
        
    }

    return 0;
}
